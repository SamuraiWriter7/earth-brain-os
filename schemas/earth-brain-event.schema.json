{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://samuraiwriter7.github.io/earth-brain-os/schemas/earth-brain-event.schema.json",
  "title": "Earth Brain Event",
  "description": "Integrated schema for Earth Brain OS v0.2 Modular Event Architecture.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "created_at",
    "status",
    "architecture",
    "layers",
    "integration_policy",
    "trace_requirements",
    "governance_hooks"
  ],

  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^earth-brain-event:[a-z0-9][a-z0-9.*:-]*$"
    },
    "event_type": {
      "type": "string",
      "const": "earth_brain_event"
    },
    "event_version": {
      "type": "string",
      "pattern": "^v?\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.-]+)?$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "experimental", "active", "deprecated", "retired", "superseded"]
    },
    "description": {
      "type": "string"
    },

    "architecture": { "$ref": "#/$defs/architecture" },
    "event_context": { "$ref": "#/$defs/event_context" },

    "layers": {
      "$ref": "#/$defs/layers"
    },

    "layer_order": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "ai_agent_layer",
          "optical_nervous_layer",
          "knowledge_cortex_layer",
          "trace_attribution_layer",
          "royalty_circulation_layer",
          "kazene_regulation_layer",
          "defense_immune_layer",
          "human_governance_layer"
        ]
      },
      "uniqueItems": true
    },

    "cross_layer_links": {
      "type": "array",
      "items": { "$ref": "#/$defs/cross_layer_link" },
      "default": []
    },

    "integration_policy": { "$ref": "#/$defs/integration_policy" },
    "trace_requirements": { "$ref": "#/$defs/trace_requirements" },
    "governance_hooks": { "$ref": "#/$defs/governance_hooks" },

    "extension_fields": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  },

  "$defs": {
    "architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "architecture_name",
        "architecture_version",
        "schema_profile",
        "integration_mode",
        "layer_count"
      ],
      "properties": {
        "architecture_name": {
          "type": "string",
          "const": "Earth Brain OS Modular Event Architecture"
        },
        "architecture_version": { "type": "string" },
        "schema_profile": {
          "type": "string",
          "const": "modular_event_architecture"
        },
        "integration_mode": {
          "type": "string",
          "enum": ["ref_based", "embedded_layers", "hybrid"]
        },
        "layer_count": {
          "type": "integer",
          "const": 8
        },
        "design_principles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "modularity",
              "traceability",
              "human_governance",
              "value_circulation",
              "defense_resilience",
              "kazene_regulation",
              "knowledge_integrity",
              "agent_coordination",
              "optical_connectivity",
              "other"
            ]
          }
        }
      }
    },

    "event_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "context_id": { "type": "string" },
        "context_type": { "type": "string" },
        "summary": { "type": "string" },
        "related_documents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "layers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ai_agent_layer",
        "optical_nervous_layer",
        "knowledge_cortex_layer",
        "trace_attribution_layer",
        "royalty_circulation_layer",
        "kazene_regulation_layer",
        "defense_immune_layer",
        "human_governance_layer"
      ],
      "properties": {
        "ai_agent_layer": {
          "$ref": "https://samuraiwriter7.github.io/earth-brain-os/schemas/layers/ai-agent-layer.schema.json"
        },
        "optical_nervous_layer": {
          "$ref": "https://samuraiwriter7.github.io/earth-brain-os/schemas/layers/optical-nervous-layer.schema.json"
        },
        "knowledge_cortex_layer": {
          "$ref": "https://samuraiwriter7.github.io/earth-brain-os/schemas/layers/knowledge-cortex-layer.schema.json"
        },
        "trace_attribution_layer": {
          "$ref": "https://samuraiwriter7.github.io/earth-brain-os/schemas/layers/trace-attribution-layer.schema.json"
        },
        "royalty_circulation_layer": {
          "$ref": "https://samuraiwriter7.github.io/earth-brain-os/schemas/layers/royalty-circulation-layer.schema.json"
        },
        "kazene_regulation_layer": {
          "$ref": "https://samuraiwriter7.github.io/earth-brain-os/schemas/layers/kazene-regulation-layer.schema.json"
        },
        "defense_immune_layer": {
          "$ref": "https://samuraiwriter7.github.io/earth-brain-os/schemas/layers/defense-immune-layer.schema.json"
        },
        "human_governance_layer": {
          "$ref": "https://samuraiwriter7.github.io/earth-brain-os/schemas/layers/human-governance-layer.schema.json"
        }
      }
    },

    "cross_layer_link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "link_id",
        "source_layer",
        "target_layer",
        "relationship",
        "description"
      ],
      "properties": {
        "link_id": { "type": "string" },
        "source_layer": { "type": "string" },
        "target_layer": { "type": "string" },
        "relationship": { "type": "string" },
        "description": { "type": "string" },
        "event_types": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required": { "type": "boolean" }
      }
    },

    "integration_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layer_validation_required",
        "cross_layer_consistency_required",
        "missing_layer_policy",
        "version_alignment_policy",
        "failure_policy"
      ],
      "properties": {
        "layer_validation_required": { "type": "boolean" },
        "cross_layer_consistency_required": { "type": "boolean" },
        "missing_layer_policy": { "type": "string" },
        "version_alignment_policy": { "type": "string" },
        "failure_policy": { "type": "string" },
        "future_lifecycle_ref": { "type": "string" }
      }
    },

    "trace_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_required",
        "layer_trace_required",
        "cross_layer_trace_required",
        "provenance_required"
      ],
      "properties": {
        "trace_required": { "type": "boolean" },
        "layer_trace_required": { "type": "boolean" },
        "cross_layer_trace_required": { "type": "boolean" },
        "provenance_required": { "type": "boolean" },
        "minimum_provenance_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "retention_policy": { "type": "string" }
      }
    },

    "governance_hooks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "human_review_boundary",
        "escalation_channels",
        "governance_layer_required"
      ],
      "properties": {
        "human_review_boundary": { "type": "string" },
        "governance_layer_required": { "type": "boolean" },
        "policy_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "constitutional_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "escalation_channels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "failure_modes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
